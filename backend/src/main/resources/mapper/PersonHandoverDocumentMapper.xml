<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aipm.backend.mapper.PersonHandoverDocumentMapper">
    <resultMap id="BaseResultMap" type="com.aipm.backend.entity.PersonHandoverDocument">
        <id column="id" property="id" />
        <result column="person_id" property="personId" />
        <result column="project_id" property="projectId" />
        <result column="file_name" property="fileName" />
        <result column="stored_path" property="storedPath" />
        <result column="document_type" property="documentType" />
        <result column="summary" property="summary" />
        <result column="uploaded_at" property="uploadedAt" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <select id="findByPersonId" resultMap="BaseResultMap">
        SELECT *
        FROM person_handover_documents
        WHERE person_id = #{personId}
        ORDER BY uploaded_at DESC, id DESC
    </select>

    <select id="findByPersonAndProject" resultMap="BaseResultMap">
        SELECT *
        FROM person_handover_documents
        WHERE person_id = #{personId}
          AND project_id = #{projectId}
        ORDER BY uploaded_at DESC, id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO person_handover_documents (
            person_id,
            project_id,
            file_name,
            stored_path,
            document_type,
            summary,
            uploaded_at
        )
        VALUES (
            #{personId},
            #{projectId},
            #{fileName},
            #{storedPath},
            #{documentType},
            #{summary},
            COALESCE(#{uploadedAt}, CURRENT_TIMESTAMP)
        )
    </insert>

    <delete id="delete">
        DELETE FROM person_handover_documents WHERE id = #{id}
    </delete>
</mapper>
